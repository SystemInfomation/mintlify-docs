{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Pals Club Support",
  "colors": {
    "primary": "#6366F1",
    "light": "#818CF8",
    "dark": "#4338CA"
  },
  "favicon": "/favicon.svg",
  "search": {
    "prompt": "Search Pals Club help articles..."
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Support Hub",
        "icon": "life-ring",
        "groups": [
          {
            "group": "Welcome",
            "pages": [
              "index",
              "faq",
              "glossary"
            ]
          },
          {
            "group": "Getting Started",
            "pages": [
              "getting-started/quickstart",
              "getting-started/system-requirements"
            ]
          },
          {
            "group": "Account & Billing",
            "pages": [
              "account-billing/manage-account",
              "account-billing/billing-subscriptions",
              "account-billing/account-recovery"
            ]
          },
          {
            "group": "Using Pals Club",
            "pages": [
              "using-pals-club/features-overview",
              "using-pals-club/core-workflows"
            ]
          }
        ]
      },
      {
        "tab": "Troubleshooting",
        "icon": "wrench",
        "groups": [
          {
            "group": "Troubleshooting",
            "pages": [
              "troubleshooting/common-issues",
              "troubleshooting/playbook",
              "troubleshooting/diagnostics"
            ]
          },
          {
            "group": "Status & Incidents",
            "pages": [
              "status-incidents"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Support Hub",
          "href": "/",
          "icon": "life-ring"
        },
        {
          "anchor": "Status Page",
          "href": "/status-incidents",
          "icon": "signal"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Contact Support",
        "href": "/contact-support/contact"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Pals Club",
      "href": "https://palsclub.example.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/palsclub",
      "github": "https://github.com/SystemInfomation/pals-club"
    }
  }
}
